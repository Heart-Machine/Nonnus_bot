BOT_TOKEN=123456789:replace_with_token_from_botfather

# Optional. Useful when Instagram blocks anonymous downloads.
# Export cookies from your own browser session in Netscape format.
COOKIES_FILE=

# Telegram may reject large uploads depending on current Bot API limits.
MAX_FILE_SIZE_MB=50

# Increase this if Telegram upload times out on larger videos or slow connections.
UPLOAD_TIMEOUT_SECONDS=180

# Required for Telegram Inline Mode.
# Create a private group/channel, add the bot, send /chatid there, and paste the ID here.
STORAGE_CHAT_ID=

# How long inline mode waits for first-time download/upload before showing "preparing".
INLINE_PREPARE_WAIT_SECONDS=8

# Optional. Stores Telegram file_id cache for already prepared reels.
INLINE_CACHE_FILE=.inline_cache.json
